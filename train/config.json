{
  "model_name": "distilgpt2",
  "dataset_dir": "data/processed",
  "output_dir": "train/outputs",
  "seed": 42,
  "num_epochs": 3,
  "batch_size": 4,
  "gradient_accumulation_steps": 2,
  "learning_rate": 5e-5,
  "weight_decay": 0.01,
  "warmup_ratio": 0.1,
  "max_seq_length": 256,
  "fp16": false,
  "lora": {
    "enabled": true,
    "r": 8,
    "alpha": 16,
    "dropout": 0.05,
    "target_modules": ["c_attn", "c_proj"]
  },
  "logging_steps": 10,
  "save_strategy": "epoch"
}
